<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.StudentMapper">
			<!-- id= Mapper 안의 함수 이름--> <!-- resultType = model에 있는 클래스-->
	<select id="selectStudentList" resultType="com.example.demo.model.Student">
		SELECT *
		FROM Student
		<!-- 쿼리문으로 데이터 가져옴 ResultSet rs = executeQuery(sql); 안해도 됨 -->
	</select>
	
	<delete id="deleteStudent" parameterType="hashmap">
		DELETE FROM STUDENT WHERE STU_NO = #{stuNo};
	</delete>
	
</mapper>